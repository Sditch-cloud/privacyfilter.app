---
import "../../../styles/global.css";
import { i18n, localeNames, localeIsRtl } from "../../../lib/i18n.js";
import {
  allBlogLocales,
  blogIndexPath,
  formatPostDate,
  getPostsForLocale,
  htmlLangFor,
  localeFromLangParam,
  localizedLangParams,
  ogLocaleFor,
  postSlug
} from "../../../lib/blog";
import BlogLanguageSwitcher from "../../../components/BlogLanguageSwitcher.astro";

export async function getStaticPaths() {
  return localizedLangParams.map(({ lang }) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = localeFromLangParam(lang!);
if (!locale) {
  return Astro.redirect("/blog/");
}

const t = i18n[locale];
const tBlog = t.blog;
const posts = await getPostsForLocale(locale);
const repoUrl = "https://github.com/becoolme/privacyfilter.app";
const homeHref = `/${lang}/`;
const languageOptions = localeNames.map((l) => ({
  locale: l.locale,
  label: l.label,
  href: blogIndexPath(l.locale)
}));
---

<!doctype html>
<html lang={htmlLangFor(locale)} dir={localeIsRtl[locale] ? "rtl" : "ltr"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tBlog.pageTitle}</title>
    <meta name="description" content={tBlog.metaDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#1769e0" />
    <meta name="color-scheme" content="light" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%231769e0'/%3E%3Cpath d='M50 22 28 32v18c0 14 9 22 22 28 13-6 22-14 22-28V32L50 22zm0 14 14 6v8c0 9-6 14-14 18-8-4-14-9-14-18v-8l14-6z' fill='%23fff'/%3E%3C/svg%3E"
    />
    {allBlogLocales.map((l) => (
      <link rel="alternate" hreflang={htmlLangFor(l)} href={blogIndexPath(l)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={blogIndexPath("en")} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={tBlog.pageTitle} />
    <meta property="og:description" content={tBlog.metaDescription} />
    <meta property="og:site_name" content="Privacy Filter" />
    <meta property="og:locale" content={ogLocaleFor(locale)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tBlog.pageTitle} />
    <meta name="twitter:description" content={tBlog.metaDescription} />
  </head>
  <body class="bg-bg text-text">
    <main class="mx-auto w-full max-w-[860px] px-4 py-8 lg:py-9">
      <header
        role="banner"
        class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3 pt-1 pb-5"
      >
        <a
          class="inline-flex items-center gap-2.5 text-text no-underline"
          href={homeHref}
          aria-label={t.homeLinkLabel}
        >
          <span
            aria-hidden="true"
            class="inline-grid place-items-center w-[30px] h-[30px] bg-accent text-white text-xs font-extrabold tracking-wider"
            >PF</span
          >
          <strong class="font-extrabold tracking-tight text-base">Privacy Filter</strong>
        </a>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <nav aria-label="Primary" class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
            <a class="text-muted no-underline hover:text-accent transition-colors" href={homeHref}>{tBlog.navHome}</a>
            <a class="text-text no-underline font-semibold" href={blogIndexPath(locale)} aria-current="page">{t.navBlog}</a>
            <a
              class="text-muted no-underline hover:text-accent transition-colors"
              href={repoUrl}
              target="_blank"
              rel="noopener">{t.navGithub}</a
            >
          </nav>
          <BlogLanguageSwitcher
            currentLocale={locale}
            options={languageOptions}
            menuLabel={t.languageMenu}
          />
        </div>
      </header>

      <section class="mb-8">
        <h1 class="m-0 mb-3 text-[clamp(30px,4vw,44px)] leading-[1.08] tracking-tight font-bold">
          {tBlog.heading}
        </h1>
        <p class="m-0 text-muted text-[16px] leading-[1.65] max-w-[640px]">{tBlog.intro}</p>
      </section>

      {posts.length === 0 ? (
        <p class="text-muted">{tBlog.empty}</p>
      ) : (
        <ul class="m-0 p-0 list-none grid gap-4">
          {posts.map((post) => (
            <li class="border border-line bg-panel p-5 hover:border-accent transition-colors">
              <a class="no-underline text-text block" href={`${blogIndexPath(locale)}${postSlug(post)}/`}>
                <div class="flex items-center gap-3 mb-2 text-xs text-muted">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatPostDate(post.data.pubDate, locale)}
                  </time>
                  {post.data.tags.length > 0 && (
                    <span class="flex flex-wrap gap-1.5">
                      {post.data.tags.map((tag) => (
                        <span class="px-1.5 py-0.5 bg-bg border border-line text-[11px] uppercase tracking-wider">
                          {tag}
                        </span>
                      ))}
                    </span>
                  )}
                </div>
                <h2 class="m-0 mb-1.5 text-xl font-semibold leading-snug">
                  {post.data.title}
                </h2>
                <p class="m-0 text-muted text-sm leading-[1.6]">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )}

      <footer
        role="contentinfo"
        class="mt-10 pt-5 pb-9 border-t border-line text-[13px] text-muted"
      >
        <p class="my-0 text-center">
          <a class="text-accent hover:underline" href={homeHref}>{tBlog.backHome}</a>
        </p>
        <nav aria-label={t.languageMenu} class="mt-4 flex flex-col items-center gap-1.5">
          <span class="text-muted font-semibold uppercase tracking-wider text-[11px]">{t.languageMenu}</span>
          <ul class="m-0 p-0 list-none flex flex-wrap justify-center gap-x-3 gap-y-1.5">
            {languageOptions.map((opt) => {
              const isCurrent = opt.locale === locale;
              return (
                <li>
                  <a
                    class:list={["hover:underline", isCurrent ? "text-text font-semibold" : "text-accent"]}
                    href={opt.href}
                    hreflang={htmlLangFor(opt.locale)}
                    aria-current={isCurrent ? "page" : undefined}
                  >{opt.label}</a>
                </li>
              );
            })}
          </ul>
        </nav>
      </footer>
    </main>
  </body>
</html>
